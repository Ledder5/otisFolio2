---
export interface Props {
  name: string;
  class?: string;
}

const { name, class: className } = Astro.props;

// 1. Load all SVGs
const icons = import.meta.glob('../icons/**/*.svg', { query: '?raw', import: 'default', eager: true });

// 2. Try to find the requested icon
let iconData = icons[`../icons/${name}.svg`] as string;

// 3. CRASH-PROOF FALLBACK: If missing, render a warning triangle instead of halting the page
if (!iconData) {
  console.warn(`⚠️ [Icon Warning] Could not find "${name}.svg" in src/icons/`);
  
  // Renders a simple warning SVG so the page keeps working
  iconData = `<svg class="text-red-500 w-8 h-8 ${className || ''}" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>`;
} else if (className) {
  // 4. Inject Tailwind classes safely
  iconData = iconData.replace('<svg', `<svg class="${className}"`);
}
---

<Fragment set:html={iconData} />