---
import Icon from '../components/Icon.astro';
import localTechData from '../data/tech.json';

interface Skill {
  name: string;
  level: number;
  icon: string;
}

interface Category {
  title: string;
  skills: Skill[];
}

const BASE_URL = import.meta.env.PUBLIC_API_BASE_URL;
let categories: Category[];

try {
  if (BASE_URL) {
    const response = await fetch(`${BASE_URL}/tech`);
    const data = await response.json();
    categories = data.categories;
  } else {
    categories = localTechData.categories;
  }
} catch {
  categories = localTechData.categories;
}
---

<section id="tech" class="section-container overflow-hidden">
  <div class="container mx-auto">
    <div class="tech-header flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16">
      <div>
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-maintext mb-2 flex items-center gap-4">
          <span class="text-accent">/</span> My Skills
        </h2>
        <p class="text-subtext font-body text-sm max-w-md">
          Overview of software, hardware, and processes I have experience with.
        </p>
      </div>

      <div class="flex flex-wrap gap-4 p-3 rounded-xl bg-accent/5 border border-accent/10 backdrop-blur-sm">
        {[
          { label: "Expert", level: 3 },
          { label: "Proficient", level: 2 },
          { label: "Beginner", level: 1 }
        ].map((item, index) => (
          <div class={`flex items-center gap-2 ${index > 0 ? 'md:border-l md:border-white/10 md:pl-4' : ''}`}>
            <div class="flex gap-0.5">
              {[1, 2, 3].map((star) => (
                <Icon 
                  name="MdiStar" 
                  class={`w-3 h-3 ${star <= item.level ? 'text-accent drop-shadow-[0_0_3px_var(--color-accent)]' : 'text-gray-600'}`} 
                />
              ))}
            </div>
            <span class="text-[10px] uppercase tracking-wider text-subtext">{item.label}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="space-y-6">
      {categories.map((category) => (
        /* We swapped <details> for <div> and use an 'is-open' class to control state */
        <div class="tech-category group bg-accent/5 rounded-2xl border border-accent/10 p-3 sm:p-4 md:!bg-transparent md:!border-none md:!p-0">
          
          <button class="tech-toggle w-full flex justify-between items-center cursor-pointer mb-0 md:pointer-events-none group-[.is-open]:mb-4 md:group-[.is-open]:mb-3 transition-all">
            <h3 class="text-maintext font-body text-xs sm:text-sm uppercase tracking-[0.3em] ml-1 text-left">
              {category.title}
            </h3>
            
            {/* Increased from w-5 h-5 to w-7 h-7 */}
            <Icon 
              name="MdiChevronDown" 
              class="w-7 h-7 text-accent transition-transform duration-500 group-[.is-open]:rotate-180 md:hidden shrink-0" 
            />
          </button>
          
          {/* THE MAGIC WRAPPER: Animates height from 0 to its full natural size */}
          <div class="grid grid-rows-[0fr] opacity-0 group-[.is-open]:grid-rows-[1fr] group-[.is-open]:opacity-100 transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]">
            <div class="overflow-hidden min-h-0">
              
              {/* The Grid of Skills */}
              <div class="grid grid-cols-2 sm:grid-cols-4 md:grid-cols-5 xl:grid-cols-6 2xl:grid-cols-7 gap-5 sm:gap-8 pt-2 md:pt-0 pb-3">
                {category.skills.map((skill) => (
                  <div class="skill-card opacity-0 relative flex items-stretch min-h-14 rounded-xl bg-background border border-accent/15 hover:border-accent/40 hover:bg-accent/10 transition-all duration-300">
                    <div class="shrink-0 w-12 flex items-center justify-center rounded-l-xl bg-accent/15 transition-colors hover:bg-accent/20">
                      <Icon name={skill.icon} class="w-7 h-7 hover:scale-110 transition-transform" />
                    </div>
                    
                    <div class="flex items-center px-3 py-2 overflow-hidden w-full">
                      <span class="font-body text-maintext/90 text-[13px] leading-tight font-medium tracking-tight line-clamp-2">
                        {skill.name}
                      </span>
                    </div>

                    <div class="absolute -bottom-2 -right-1 z-10 flex gap-0 px-1 py-0.5 bg-container rounded-md border border-white/10 shadow-lg transition-all">
                      {[1, 2, 3].map((star) => (
                        <Icon 
                          name="MdiStar" 
                          class={`w-3 h-3 transition-colors duration-500 ${
                            star <= skill.level 
                              ? 'text-accent drop-shadow-[0_0_3px_var(--color-accent)]' 
                              : 'text-gray-600'
                          }`} 
                        />
                      ))}
                    </div>
                  </div>
                ))}
              </div>
              
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Header Initial State */
  .tech-header {
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Initial state of the card */
  .skill-card {
    transform: translateY(20px) scale(0.95);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Shared Revealed state */
  .tech-header.reveal,
  .skill-card.reveal {
    opacity: 1 !important;
    transform: translateY(0) scale(1);
  }
</style>

<script>
  function revealSkills() {
    const header = document.querySelector('.tech-header');
    const cards = document.querySelectorAll('.skill-card');
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const target = entry.target;
          
          if (target.classList.contains('tech-header')) {
            target.classList.add('reveal');
            observer.unobserve(target);
          }
          else if (target.classList.contains('skill-card')) {
            const index = Array.from(cards).indexOf(target);
            setTimeout(() => {
              target.classList.add('reveal');
            }, (index % 6) * 50); 
            observer.unobserve(target);
          }
        }
      });
    }, {
      threshold: 0.1, 
      rootMargin: '0px 0px -50px 0px' 
    });

    if (header) observer.observe(header);
    cards.forEach(card => observer.observe(card));
  }

  // --- Desktop Dropdown Logic ---
  // --- Desktop Dropdown & Animation Logic ---
  function initTechDropdowns() {
    const categories = document.querySelectorAll('.tech-category');
    let wasDesktop = window.innerWidth >= 768;

    // 1. Listen for clicks on mobile
    categories.forEach(category => {
      const toggleBtn = category.querySelector('.tech-toggle');
      
      // Safety check: only add the listener once to avoid Astro transition bugs
      if (toggleBtn && !toggleBtn.hasAttribute('data-bound')) {
        toggleBtn.addEventListener('click', () => {
          if (window.innerWidth < 768) {
            category.classList.toggle('is-open');
          }
        });
        toggleBtn.setAttribute('data-bound', 'true');
      }
    });

    // 2. Handle screen resizing
    const handleResize = () => {
      const isDesktop = window.innerWidth >= 768;
      
      if (isDesktop) {
        // Force open on desktop
        categories.forEach(c => c.classList.add('is-open'));
      } else if (wasDesktop && !isDesktop) {
        // Close if dragging the window down to mobile size
        categories.forEach(c => c.classList.remove('is-open'));
      }
      
      wasDesktop = isDesktop;
    };

    // Run immediately on page load
    if (wasDesktop) {
      categories.forEach(c => c.classList.add('is-open'));
    }

    window.addEventListener('resize', handleResize);
  }

  // Run initializers
  revealSkills();
  initTechDropdowns();
  
  // Support for Astro View Transitions
  document.addEventListener('astro:after-swap', () => {
    revealSkills();
    initTechDropdowns();
  });
</script>