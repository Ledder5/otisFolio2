---
import Layout from '../../layouts/Layout.astro';
import projectsData from '../../data/projects.json';
import Icon from '../../components/Icon.astro';
import { Image } from 'astro:assets';
import { resolveAssetImage } from '../../utils/images';

// 1. Tell Astro which URLs to generate
export async function getStaticPaths() {
  return projectsData
    .filter((project) => project.slug)
    .map((project) => ({
      params: { slug: project.slug },
    }));
}

// 2. Grab the specific slug from the current page's URL
const { slug } = Astro.params;

// 3. Find the exact project in our JSON file that matches this slug
const project = projectsData.find((p) => p.slug === slug);

// 4. Safety Check: If no project is found (bad URL), redirect back home
if (!project) {
  return Astro.redirect('/#projects');
}

// 5. Resolve the hero image safely now that we guarantee 'project' exists
const heroImageMetadata = project.images && project.images.length > 0
  ? await resolveAssetImage(project.images[0])
  : null;
---

<Layout title={`${project.title} | Portfolio`}>
  
  <main class="pt-24 pb-20 max-w-4xl mx-auto px-6 sm:px-12 relative z-10">
    
    <a href="/#projects" class="inline-flex items-center gap-2 text-subtext hover:text-accent transition-colors font-body text-sm mb-12 group">
      <div class="p-2 rounded-full bg-accent/5 group-hover:bg-accent/20 transition-colors border border-accent/10">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-x-1 transition-transform"><path d="m15 18-6-6 6-6"/></svg>
      </div>
      Back to Projects
    </a>

    <header class="mb-12">
      <span class="text-accent text-xs uppercase tracking-widest font-bold">{project.category}</span>
      <h1 class="text-4xl md:text-6xl font-heading font-bold text-maintext tracking-tight mt-3 mb-8">
        {project.title}
      </h1>
      
      <div class="flex flex-wrap gap-2">
        {project.tech.map((t: string) => (
          <span class="rounded-md text-[11px] px-4 py-1.5 bg-accent/10 border border-accent/20 text-accent">
            {t}
          </span>
        ))}
      </div>
    </header>

    {heroImageMetadata && (
      <div class="w-full aspect-video rounded-3xl overflow-hidden mb-16 border border-accent/10 shadow-[0_0_40px_rgba(var(--accent-rgb),0.1)]">
        <Image 
          src={heroImageMetadata} 
          alt={project.title} 
          class="w-full h-full object-cover"
        />
      </div>
    )}

    <article class="prose prose-invert prose-p:text-subtext prose-p:font-body prose-p:leading-relaxed prose-headings:font-heading prose-headings:text-maintext prose-a:text-accent hover:prose-a:text-accent/80 max-w-none">
      
      <p class="text-xl sm:text-2xl text-maintext/90 font-light mb-12 leading-relaxed">
        {project.description}
      </p>
      
      <div class="h-px w-full bg-gradient-to-r from-accent/0 via-accent/20 to-accent/0 mb-12"></div>

      <h2 class="text-2xl font-bold mb-4">About the Project</h2>
      <p>
        This is a placeholder for your dedicated project write-up. Right now, this is hardcoded text in the <code>[slug].astro</code> file. 
      </p>
      <p>
        In the future, we can upgrade this by adding a <code>long_description</code> to your JSON file, or even swapping out JSON entirely in favor of <strong>Astro Content Collections (Markdown files)</strong> for a true blogging experience!
      </p>

      {project.link && (
        <div class="mt-16">
          <a href={project.link} target="_blank" class="no-underline inline-flex items-center gap-3 px-8 py-4 rounded-xl bg-accent text-background font-heading font-bold hover:bg-accent/90 transition-all hover:-translate-y-1 shadow-lg shadow-accent/20">
            Visit Live Project <Icon name="MdiOpenInNew" class="w-5 h-5" />
          </a>
        </div>
      )}
    </article>

  </main>
</Layout>